<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="SeleniumCraft Demo Suite" verbose="2" parallel="false">

    <!-- Global Listeners for Reporting -->
    <listeners>
        <listener class-name="com.seleniumcraft.reporting.ExtentTestListener"/>
    </listeners>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 1: FLAKY TESTS (Traditional Selenium - Expected to FAIL)    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    
    <test name="❌ Flaky Basic Selenium Tests (Expected Failures)">
        <classes>
            <class name="com.seleniumcraft.demo.FlakyBasicSeleniumTest">
                <methods>
                    <include name="testStaleElementException_WillFail"/>
                    <include name="testDynamicLoadingRaceCondition_WillFail"/>
                    <include name="testDisappearingElement_WillFail"/>
                    <include name="testRapidClicksStaleElement_WillFail"/>
                    <include name="testWithThreadSleep_SlowAndFragile"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 2: DEMO SUITES (Kept: Flaky + SeleniumCraft)                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <test name="SeleniumCraft - Demo">
        <classes>
            <class name="com.seleniumcraft.demo.SeleniumCraftTest"/>
        </classes>
    </test>

    <test name="Flaky Basic Selenium - Demo">
        <classes>
            <class name="com.seleniumcraft.demo.FlakyBasicSeleniumTest"/>
        </classes>
    </test>

</suite>
